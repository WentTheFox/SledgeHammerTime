			count: 1
			path: app/Services/Discord/DiscordUserService.php

		-
			message: '#^Static method Redis\:\:set\(\) invoked with 4 parameters, 2\-3 required\.$#'
			identifier: arguments.count
			count: 1
			path: app/Services/Discord/DiscordUserService.php
