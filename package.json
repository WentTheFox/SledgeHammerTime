{
  "name": "sledgehammertime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-translation-credits": "tsx --tsconfig ./tsconfig.utils.json ./utils/translation-credits.ts --force",
    "dev:server": "vite",
    "dev:queue": "sudo service horizon restart && sudo journalctl -xefu horizon --since \"$(date +\"%Y-%m-%d %H:%M:%S\")\"",
    "dev": "concurrently -p name pnpm:dev:*",
    "lint": "eslint resources/**/*.{ts,vue}",
    "build:type-check": "vue-tsc",
    "build:static": "vite build",
    "build:ssr": "vite build --ssr",
    "build": "concurrently -p name pnpm:build:*",
    "ssr": "php artisan inertia:start-ssr",
    "test": "vitest --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inertiajs/core": "3.2.0",
    "@inertiajs/vite": "^3.2.0",
    "@inertiajs/vue3": "^3.2.0",
    "@types/js-cookie": "^3.0.6",
    "@types/js-levenshtein": "^1.1.3",
    "@types/md5": "^2.3.6",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/language-server": "^3.3.1",
    "@vue/server-renderer": "^3.5.34",
    "@wentthefox-forks/vite-plugin-imagemin": "^2.2.2",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "classnames": "^2.5.1",
    "concurrently": "^9.2.1",
    "deepmerge-ts": "^7.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "js-cookie": "^3.0.7",
    "laravel-vite-plugin": "^3.1.0",
    "laravel-vue-i18n": "^2.8.0",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.15",
    "sass": "^1.100.0",
    "sharp": "^0.34.5",
    "tippy.js": "6.3.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-country-flag-next": "^2.3.2",
    "vue-tippy": "^6.7.1",
    "vue-tsc": "^3.3.1",
    "ziggy-js": "^2.6.2"
  },
  "dependencies": {
    "@date-fns/tz": "^1.5.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@vueuse/core": "^14.3.0",
    "chart.js": "^4.5.1",
    "chrono-node": "^2.9.1",
    "date-fns": "^4.3.0",
    "js-levenshtein": "^1.1.6",
    "lorem-ipsum": "^2.0.10",
    "md5": "^2.3.0",
    "playwright": "^1.60.0",
    "the-new-css-reset": "^1.11.3",
    "vue-chartjs": "^5.3.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
